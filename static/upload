<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>File Upload</title>
    <style>
        #dropzone {
            width: 300px;
            height: 150px;
            border: 2px dashed #aaa;
            border-radius: 10px;
            text-align: center;
            line-height: 150px;
            color: #666;
            font-family: sans-serif;
            margin: 50px auto;
        }
    </style>
</head>
<body>

<div id="dropzone">Drop a file here</div>

<script>
document.getElementById('dropzone').addEventListener('dragover', function(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'copy';
});

document.getElementById('dropzone').addEventListener('drop', function(e) {
    e.preventDefault();
    const file = e.dataTransfer.files[0];
    if (!file) return;

    const formData = new FormData();
    formData.append('file', file);

    fetch('/cgis/upload.py', {
        method: 'POST',
        body: formData
    }).then(response => {
        if (response.ok) {
            alert('File uploaded successfully.');
        } else {
            alert('Upload failed.');
        }
    }).catch(err => {
        alert('Error: ' + err);
    });
});
</script>

<form method="GET" action="/cgis/read_file.py">
    <label for="reading">Read an uploaded file (by name):</label>
    <input type="text" name="filename" id="reading" />
    <button type="submit">Send</button>
</form>

<label for="deleting">Delete a file (by name):</label>
<input type="text" id="filename"/>
<button id="deleteButton">Send</button>

<script>
document.getElementById('deleteButton').addEventListener('click', function () {
    const filename = document.getElementById('filename').value;
    const encodedName = encodeURIComponent(filename);
    fetch(`/cgis/delete.py?filename=${encodedName}`, {
        method: 'DELETE'
    }).then(response => {
        if (response.ok) {
            alert('DELETE request sent successfully.');
        } else {
            alert('DELETE failed with status: ' + response.status);
        }
    }).catch(error => {
        alert('Request error: ' + error);
    });
});
</script>

</form>

</body>
</html>
